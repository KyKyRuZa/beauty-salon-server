# syntax=docker/dockerfile:1

FROM node:24-alpine

LABEL maintainer="Beauty Vite Team"
LABEL description="Backend development server for Beauty Vite application"
LABEL version="1.0"

WORKDIR /app

COPY package*.json ./

RUN npm ci

COPY . .

EXPOSE 5000
EXPOSE 9229

ENV NODE_ENV=development
ENV LOG_LEVEL=debug
ENV NODE_OPTIONS=--inspect=0.0.0.0:9229

CMD ["npm", "run", "dev"]
